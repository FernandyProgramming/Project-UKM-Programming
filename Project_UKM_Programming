<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Tic Tac Toe</title>
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div id="root"></div>
    
    <script type="text/babel">
        const { useState, useEffect } = React;

        // Icons replacement (since we can't use lucide-react in HTML)
        const RotateCcw = () => <span>🔄</span>;
        const History = () => <span>📜</span>;
        const Settings = () => <span>⚙️</span>;

        // ==================== ENUMS & TYPES ====================
        const Player = {
          NONE: 'NONE',
          HUMAN: 'HUMAN',
          AI: 'AI'
        };

        const GameState = {
          ONGOING: 'ONGOING',
          WIN: 'WIN',
          DRAW: 'DRAW'
        };

        const Difficulty = {
          EASY: 'EASY',
          MEDIUM: 'MEDIUM',
          HARD: 'HARD',
          IMPOSSIBLE: 'IMPOSSIBLE'
        };

        const GameMode = {
          PVP: 'PVP',
          PVE: 'PVE'
        };

        // ==================== MOVE CLASS ====================
        class Move {
          constructor(position, player, moveNumber) {
            this.position = position;
            this.player = player;
            this.moveNumber = moveNumber;
          }
        }

        // ==================== BOARD CLASS ====================
        class Board {
          constructor(size = 3, winLength = 3) {
            this.size = size;
            this.winLength = winLength;
            this.moveHistory = [];
            this.moveCount = 0;
            this.cells = this.initializeBoard();
          }

          initializeBoard() {
            return Array(this.size * this.size).fill(null);
          }

          isValidMove(position) {
            return position >= 0 && position < this.size * this.size && this.cells[position] === null;
          }

          makeMove(position, symbol) {
            if (!this.isValidMove(position)) return false;
            
            this.cells[position] = symbol;
            const player = symbol === 'X' ? Player.HUMAN : Player.AI;
            this.moveHistory.push(new Move(position, player, ++this.moveCount));
            return true;
          }

          undoMove() {
            if (this.moveHistory.length === 0) return;
            
            const lastMove = this.moveHistory.pop();
            this.cells[lastMove.position] = null;
            this.moveCount--;
          }

          hasWinner() {
            // Check rows
            for (let row = 0; row < this.size; row++) {
              for (let col = 0; col <= this.size - this.winLength; col++) {
                const first = this.cells[row * this.size + col];
                if (!first) continue;
                
                let win = true;
                for (let k = 1; k < this.winLength; k++) {
                  if (this.cells[row * this.size + col + k] !== first) {
                    win = false;
                    break;
                  }
                }
                if (win) return true;
              }
            }

            // Check columns
            for (let col = 0; col < this.size; col++) {
              for (let row = 0; row <= this.size - this.winLength; row++) {
                const first = this.cells[row * this.size + col];
                if (!first) continue;
                
                let win = true;
                for (let k = 1; k < this.winLength; k++) {
                  if (this.cells[(row + k) * this.size + col] !== first) {
                    win = false;
                    break;
                  }
                }
                if (win) return true;
              }
            }

            // Check diagonals (top-left to bottom-right)
            for (let row = 0; row <= this.size - this.winLength; row++) {
              for (let col = 0; col <= this.size - this.winLength; col++) {
                const first = this.cells[row * this.size + col];
                if (!first) continue;
                
                let win = true;
                for (let k = 1; k < this.winLength; k++) {
                  if (this.cells[(row + k) * this.size + (col + k)] !== first) {
                    win = false;
                    break;
                  }
                }
                if (win) return true;
              }
            }

            // Check diagonals (top-right to bottom-left)
            for (let row = 0; row <= this.size - this.winLength; row++) {
              for (let col = this.winLength - 1; col < this.size; col++) {
                const first = this.cells[row * this.size + col];
                if (!first) continue;
                
                let win = true;
                for (let k = 1; k < this.winLength; k++) {
                  if (this.cells[(row + k) * this.size + (col - k)] !== first) {
                    win = false;
                    break;
                  }
                }
                if (win) return true;
              }
            }

            return false;
          }

          isFull() {
            return this.cells.every(cell => cell !== null);
          }

          getAvailableMoves() {
            return this.cells.map((cell, idx) => cell === null ? idx : null).filter(idx => idx !== null);
          }

          reset() {
            this.cells = this.initializeBoard();
            this.moveHistory = [];
            this.moveCount = 0;
          }

          clone() {
            const cloned = new Board(this.size, this.winLength);
            cloned.cells = [...this.cells];
            cloned.moveHistory = [...this.moveHistory];
            cloned.moveCount = this.moveCount;
            return cloned;
          }
        }

        // ==================== AI CLASS ====================
        class AI {
          constructor(difficulty) {
            this.difficulty = difficulty;
          }

          minimax(board, depth, isMaximizing, alpha, beta) {
            if (board.hasWinner()) {
              return isMaximizing ? -10 + depth : 10 - depth;
            }
            if (board.isFull()) return 0;
            if (depth > 6) return 0;

            const moves = board.getAvailableMoves();

            if (isMaximizing) {
              let maxEval = -10000;
              for (const move of moves) {
                board.makeMove(move, 'O');
                const eval_ = this.minimax(board, depth + 1, false, alpha, beta);
                board.undoMove();
                maxEval = Math.max(maxEval, eval_);
                alpha = Math.max(alpha, eval_);
                if (beta <= alpha) break;
              }
              return maxEval;
            } else {
              let minEval = 10000;
              for (const move of moves) {
                board.makeMove(move, 'X');
                const eval_ = this.minimax(board, depth + 1, true, alpha, beta);
                board.undoMove();
                minEval = Math.min(minEval, eval_);
                beta = Math.min(beta, eval_);
                if (beta <= alpha) break;
              }
              return minEval;
            }
          }

          getBestMove(board) {
            const moves = board.getAvailableMoves();
            if (moves.length === 0) return -1;

            switch (this.difficulty) {
              case Difficulty.EASY:
                return moves[Math.floor(Math.random() * moves.length)];

              case Difficulty.MEDIUM:
                if (Math.random() < 0.5) {
                  return moves[Math.floor(Math.random() * moves.length)];
                }

              case Difficulty.HARD:
              case Difficulty.IMPOSSIBLE: {
                let bestMove = -1;
                let bestValue = -10000;

                for (const move of moves) {
                  const clonedBoard = board.clone();
                  clonedBoard.makeMove(move, 'O');
                  const moveValue = this.minimax(clonedBoard, 0, false, -10000, 10000);

                  if (moveValue > bestValue) {
                    bestValue = moveValue;
                    bestMove = move;
                  }
                }
                return bestMove;
              }
              default:
                return moves[0];
            }
          }
        }

        // ==================== MAIN COMPONENT ====================
        function TicTacToeGame() {
          const [board, setBoard] = useState(new Board(3, 3));
          const [currentPlayer, setCurrentPlayer] = useState(Player.HUMAN);
          const [gameState, setGameState] = useState(GameState.ONGOING);
          const [mode, setMode] = useState(null);
          const [difficulty, setDifficulty] = useState(Difficulty.MEDIUM);
          const [ai, setAi] = useState(null);
          const [scores, setScores] = useState({ [Player.HUMAN]: 0, [Player.AI]: 0, draws: 0 });
          const [showHistory, setShowHistory] = useState(false);
          const [showSettings, setShowSettings] = useState(false);
          const [isThinking, setIsThinking] = useState(false);
          const [boardSize, setBoardSize] = useState(3);
          const [winLength, setWinLength] = useState(3);

          useEffect(() => {
            if (mode === GameMode.PVE && currentPlayer === Player.AI && gameState === GameState.ONGOING) {
              setIsThinking(true);
              setTimeout(() => {
                const aiMove = ai.getBestMove(board);
                if (aiMove !== -1) {
                  handleMove(aiMove);
                }
                setIsThinking(false);
              }, 500);
            }
          }, [currentPlayer, mode, gameState]);

          const checkGameState = (currentBoard) => {
            if (currentBoard.hasWinner()) {
              return GameState.WIN;
            }
            if (currentBoard.isFull()) {
              return GameState.DRAW;
            }
            return GameState.ONGOING;
          };

          const handleMove = (position) => {
            if (gameState !== GameState.ONGOING || (mode === GameMode.PVE && currentPlayer === Player.AI)) {
              return;
            }

            const newBoard = board.clone();
            const symbol = currentPlayer === Player.HUMAN ? 'X' : 'O';
            
            if (newBoard.makeMove(position, symbol)) {
              setBoard(newBoard);
              
              const newState = checkGameState(newBoard);
              setGameState(newState);
              
              if (newState === GameState.WIN) {
                setScores(prev => ({
                  ...prev,
                  [currentPlayer]: prev[currentPlayer] + 1
                }));
              } else if (newState === GameState.DRAW) {
                setScores(prev => ({ ...prev, draws: prev.draws + 1 }));
              } else {
                setCurrentPlayer(currentPlayer === Player.HUMAN ? Player.AI : Player.HUMAN);
              }
            }
          };

          const resetGame = () => {
            const newBoard = new Board(boardSize, winLength);
            setBoard(newBoard);
            setCurrentPlayer(Player.HUMAN);
            setGameState(GameState.ONGOING);
          };

          const startNewGame = (selectedMode, selectedDifficulty = Difficulty.MEDIUM) => {
            setMode(selectedMode);
            setDifficulty(selectedDifficulty);
            if (selectedMode === GameMode.PVE) {
              setAi(new AI(selectedDifficulty));
            }
            resetGame();
          };

          const applySettings = () => {
            const newBoard = new Board(boardSize, winLength);
            setBoard(newBoard);
            if (mode === GameMode.PVE) {
              setAi(new AI(difficulty));
            }
            setCurrentPlayer(Player.HUMAN);
            setGameState(GameState.ONGOING);
            setShowSettings(false);
          };

          if (!mode) {
            return (
              <div className="min-h-screen bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 flex items-center justify-center p-4">
                <div className="bg-white/10 backdrop-blur-lg rounded-2xl p-8 max-w-md w-full border border-white/20 shadow-2xl">
                  <div className="text-center mb-8">
                    <h1 className="text-4xl font-bold text-white mb-2">🎮 Tic Tac Toe</h1>
                    <p className="text-blue-200">Choose your game mode</p>
                  </div>
                  
                  <div className="space-y-4">
                    <button
                      onClick={() => startNewGame(GameMode.PVP)}
                      className="w-full bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white font-bold py-4 px-6 rounded-xl transition-all transform hover:scale-105 shadow-lg"
                    >
                      👥 Player vs Player
                    </button>
                    
                    <div className="space-y-2">
                      <p className="text-white text-center font-semibold">🤖 Player vs AI</p>
                      <div className="grid grid-cols-2 gap-2">
                        <button
                          onClick={() => startNewGame(GameMode.PVE, Difficulty.EASY)}
                          className="bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-4 rounded-lg transition-all"
                        >
                          😊 Easy
                        </button>
                        <button
                          onClick={() => startNewGame(GameMode.PVE, Difficulty.MEDIUM)}
                          className="bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-3 px-4 rounded-lg transition-all"
                        >
                          😐 Medium
                        </button>
                        <button
                          onClick={() => startNewGame(GameMode.PVE, Difficulty.HARD)}
                          className="bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-4 rounded-lg transition-all"
                        >
                          😤 Hard
                        </button>
                        <button
                          onClick={() => startNewGame(GameMode.PVE, Difficulty.IMPOSSIBLE)}
                          className="bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-4 rounded-lg transition-all"
                        >
                          😈 Impossible
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          }

          return (
            <div className="min-h-screen bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 p-4">
              <div className="max-w-4xl mx-auto">
                <div className="text-center mb-6">
                  <h1 className="text-4xl font-bold text-white mb-2">🎮 Advanced Tic Tac Toe</h1>
                  <p className="text-blue-200">
                    {mode === GameMode.PVP ? 'Player vs Player' : `Player vs AI (${difficulty})`}
                  </p>
                </div>

                <div className="bg-white/10 backdrop-blur-lg rounded-xl p-4 mb-6 border border-white/20">
                  <div className="flex justify-around items-center">
                    <div className="text-center">
                      <div className="text-3xl mb-1">❌</div>
                      <div className="text-white font-bold text-2xl">{scores[Player.HUMAN]}</div>
                      <div className="text-blue-200 text-sm">Player</div>
                    </div>
                    <div className="text-center">
                      <div className="text-3xl mb-1">🤝</div>
                      <div className="text-white font-bold text-2xl">{scores.draws}</div>
                      <div className="text-blue-200 text-sm">Draws</div>
                    </div>
                    <div className="text-center">
                      <div className="text-3xl mb-1">⭕</div>
                      <div className="text-white font-bold text-2xl">{scores[Player.AI]}</div>
                      <div className="text-blue-200 text-sm">{mode === GameMode.PVP ? 'Player 2' : 'AI'}</div>
                    </div>
                  </div>
                </div>

                <div className="bg-white/10 backdrop-blur-lg rounded-2xl p-6 mb-6 border border-white/20">
                  <div className="mb-4 text-center">
                    <p className="text-white text-lg font-semibold">
                      {gameState === GameState.ONGOING ? (
                        isThinking ? '🤔 AI is thinking...' : `Current Turn: ${currentPlayer === Player.HUMAN ? '❌ Player' : '⭕ ' + (mode === GameMode.PVP ? 'Player 2' : 'AI')}`
                      ) : gameState === GameState.WIN ? (
                        `🎉 ${currentPlayer === Player.HUMAN ? '⭕' : '❌'} ${currentPlayer === Player.HUMAN ? (mode === GameMode.PVP ? 'Player 2' : 'AI') : 'Player'} Wins!`
                      ) : (
                        '🤝 Draw!'
                      )}
                    </p>
                  </div>

                  <div 
                    className="grid gap-2 mx-auto"
                    style={{ 
                      gridTemplateColumns: `repeat(${boardSize}, minmax(0, 1fr))`,
                      maxWidth: `${boardSize * 80}px`
                    }}
                  >
                    {board.cells.map((cell, idx) => (
                      <button
                        key={idx}
                        onClick={() => handleMove(idx)}
                        disabled={cell !== null || gameState !== GameState.ONGOING || isThinking}
                        className={`aspect-square rounded-lg font-bold text-4xl transition-all transform hover:scale-105 ${
                          cell === null
                            ? 'bg-white/20 hover:bg-white/30'
                            : 'bg-white/30'
                        } ${cell !== null || gameState !== GameState.ONGOING || isThinking ? 'cursor-not-allowed' : 'cursor-pointer'}`}
                      >
                        {cell === 'X' ? '❌' : cell === 'O' ? '⭕' : ''}
                      </button>
                    ))}
                  </div>
                </div>

                <div className="flex gap-3 mb-6">
                  <button
                    onClick={resetGame}
                    className="flex-1 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold py-3 px-6 rounded-xl transition-all flex items-center justify-center gap-2"
                  >
                    🔄 New Game
                  </button>
                  <button
                    onClick={() => setShowHistory(!showHistory)}
                    className="flex-1 bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-xl transition-all flex items-center justify-center gap-2"
                  >
                    📜 History
                  </button>
                  <button
                    onClick={() => setShowSettings(!showSettings)}
                    className="flex-1 bg-gradient-to-r from-gray-500 to-gray-600 hover:from-gray-600 hover:to-gray-700 text-white font-bold py-3 px-6 rounded-xl transition-all flex items-center justify-center gap-2"
                  >
                    ⚙️ Settings
                  </button>
                </div>

                {showHistory && board.moveHistory.length > 0 && (
                  <div className="bg-white/10 backdrop-blur-lg rounded-xl p-6 mb-6 border border-white/20">
                    <h3 className="text-white font-bold text-xl mb-4 flex items-center gap-2">
                      📜 Move History
                    </h3>
                    <div className="grid grid-cols-3 gap-2 text-white text-sm">
                      <div className="font-bold">Move #</div>
                      <div className="font-bold">Player</div>
                      <div className="font-bold">Position</div>
                      {board.moveHistory.map((move, idx) => (
                        <React.Fragment key={idx}>
                          <div>{move.moveNumber}</div>
                          <div>{move.player === Player.HUMAN ? '❌' : '⭕'}</div>
                          <div>{move.position}</div>
                        </React.Fragment>
                      ))}
                    </div>
                  </div>
                )}

                {showSettings && (
                  <div className="bg-white/10 backdrop-blur-lg rounded-xl p-6 mb-6 border border-white/20">
                    <h3 className="text-white font-bold text-xl mb-4 flex items-center gap-2">
                      ⚙️ Game Settings
                    </h3>
                    <div className="space-y-4">
                      <div>
                        <label className="text-white block mb-2">Board Size: {boardSize}x{boardSize}</label>
                        <input
                          type="range"
                          min="3"
                          max="6"
                          value={boardSize}
                          onChange={(e) => {
                            const size = parseInt(e.target.value);
                            setBoardSize(size);
                            if (winLength > size) setWinLength(size);
                          }}
                          className="w-full"
                        />
                      </div>
                      <div>
                        <label className="text-white block mb-2">Win Length: {winLength}</label>
                        <input
                          type="range"
                          min="3"
                          max={boardSize}
                          value={winLength}
                          onChange={(e) => setWinLength(parseInt(e.target.value))}
                          className="w-full"
                        />
                      </div>
                      {mode === GameMode.PVE && (
                        <div>
                          <label className="text-white block mb-2">AI Difficulty</label>
                          <select
                            value={difficulty}
                            onChange={(e) => setDifficulty(e.target.value)}
                            className="w-full bg-white/20 text-white p-2 rounded-lg border border-white/30"
                          >
                            <option value={Difficulty.EASY}>😊 Easy</option>
                            <option value={Difficulty.MEDIUM}>😐 Medium</option>
                            <option value={Difficulty.HARD}>😤 Hard</option>
                            <option value={Difficulty.IMPOSSIBLE}>😈 Impossible</option>
                          </select>
                        </div>
                      )}
                      <button
                        onClick={applySettings}
                        className="w-full bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white font-bold py-3 px-6 rounded-xl transition-all"
                      >
                        Apply Settings
                      </button>
                    </div>
                  </div>
                )}

                <button
                  onClick={() => setMode(null)}
                  className="w-full bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-bold py-3 px-6 rounded-xl transition-all"
                >
                  Back to Menu
                </button>
              </div>
            </div>
          );
        }
    </script>
    
    <script type="text/babel">
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<TicTacToeGame />);
    </script>
</body>
</html>
